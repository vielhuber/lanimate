{
    "name": "lanimate",
    "version": "1.2.9",
    "main": "_build/script.js",
    "files": [
        "_build/*.js",
        "lanimate.min.js"
    ],
    "repository": {
        "type": "git",
        "url": "git+ssh://git@github.com/vielhuber/lanimate.git"
    },
    "author": "David Vielhuber <david@vielhuber.de>",
    "license": "MIT",
    "description": "",
    "scripts": {
        "js:vite": "vite build --logLevel error",
        "js:minify": "terser --compress --mangle --output ./lanimate.min.js ./lanimate.min.js",
        "js:babel": "npx babel ./_js/ --out-dir ./_build/",
        "js": "npm-run-all --sequential js:vite js:minify js:babel",
        "js:dev": "npm-run-all --sequential js:vite js:babel",
        "watch:js": "onchange ./_js/*.js --initial --poll 50 --delay 0 --await-write-finish 50 -- npm run js:dev",
        "dev": "npm-run-all --parallel watch:*",
        "prod": "npm-run-all --parallel js"
    },
    "dependencies": {
        "@babel/runtime": "^7.29.2",
        "hlp": "^3.8.1",
        "mdn-polyfills": "^5.20.0",
        "onchange": "^7.1.0"
    },
    "devDependencies": {
        "@babel/cli": "^7.28.6",
        "@babel/core": "^7.29.0",
        "@babel/plugin-proposal-class-properties": "^7.18.6",
        "@babel/plugin-proposal-optional-chaining": "^7.21.0",
        "@babel/plugin-proposal-private-methods": "^7.18.6",
        "@babel/plugin-transform-runtime": "^7.29.0",
        "@babel/polyfill": "^7.12.1",
        "@babel/preset-env": "^7.29.5",
        "auto-changelog": "^2.5.1",
        "babelify": "^10.0.0",
        "npm-run-all": "^4.1.5",
        "terser": "^5.48.0",
        "vite": "^8.0.14"
    },
    "browserslist": [
        "ie >= 11",
        "> 0.25%",
        "not dead"
    ],
    "engines": {
        "node": ">=18"
    }
}

{
    "name": "lanimate",
    "version": "1.3.2",
    "main": "_build/script.js",
    "files": [
        "_build/*.js",
        "lanimate.min.js"
    ],
    "repository": {
        "type": "git",
        "url": "git+ssh://git@github.com/vielhuber/lanimate.git"
    },
    "author": "David Vielhuber <david@vielhuber.de>",
    "license": "MIT",
    "description": "",
    "scripts": {
        "js:vite": "vite build --logLevel error",
        "js:minify": "terser --compress --mangle --output ./lanimate.min.js ./lanimate.min.js",
        "js:package": "vite build --logLevel error --mode package",
        "js": "npm-run-all --sequential js:vite js:minify js:package",
        "js:dev": "npm-run-all --sequential js:vite js:package",
        "watch:js": "onchange ./_js/*.js --initial --poll 50 --delay 0 --await-write-finish 50 -- npm run js:dev",
        "dev": "npm-run-all --parallel watch:*",
        "prod": "npm-run-all --parallel js"
    },
    "dependencies": {
        "hlp": "^3.8.6",
        "onchange": "^7.1.0"
    },
    "devDependencies": {
        "auto-changelog": "^2.6.0",
        "npm-run-all": "^4.1.5",
        "terser": "^5.48.0",
        "vite": "^8.1.0"
    },
    "browserslist": [
        "> 0.25%",
        "not dead"
    ],
    "overrides": {
        "shell-quote": "^1.8.4"
    },
    "engines": {
        "node": ">=18"
    }
}
